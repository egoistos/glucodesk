{
  "appId": "com.glucodesk.app",
  "productName": "GlucoDesk",
  "directories": {
    "buildResources": "build",
    "output": "dist"
  },
  "files": [
    "out/**/*",
    "assets/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/icons/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "GlucoDesk",
    "runAfterFinish": true,
    "include": "build/installer.nsh",
    "deleteAppDataOnUninstall": true
  },
  "extraResources": [
    {
      "from": "assets/sounds",
      "to": "sounds"
    }
  ]
}
